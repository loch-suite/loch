---
const { activePage = '' } = Astro.props;

const links = [
  { href: '/downloads', label: 'Downloads' },
  { href: '/changelog', label: 'Changelog' },
  { href: '/about',     label: 'About'     },
];
---

<nav id="loom-nav" class="fixed top-0 left-0 right-0 z-50">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-2.5 select-none group" style="text-decoration: none;">
      <!-- 4-node graph icon mark -->
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg"
           style="color: var(--text-primary); opacity: 0.85; transition: opacity 120ms ease;"
           class="group-hover:opacity-100">
        <line x1="4" y1="4" x2="14" y2="4"  stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="4" y1="14" x2="14" y2="14" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="4" y1="4" x2="4"  y2="14" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="14" y1="4" x2="14" y2="14" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
        <circle cx="4"  cy="4"  r="2.2" fill="currentColor"/>
        <circle cx="14" cy="4"  r="2.2" fill="currentColor"/>
        <circle cx="4"  cy="14" r="2.2" fill="currentColor"/>
        <circle cx="14" cy="14" r="2.2" fill="currentColor"/>
      </svg>
      <span class="font-display font-bold uppercase tracking-brand text-sm group-hover:opacity-100"
            style="color: var(--text-primary); opacity: 0.85; letter-spacing: 0.14em; transition: opacity 120ms ease;">
        LOCH
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      <!-- Apps dropdown trigger -->
      <div class="relative group">
        <button class="nav-link flex items-center gap-1">
          Apps
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="opacity-40 transition-transform duration-fast group-hover:rotate-180">
            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <!-- Dropdown -->
        <div class="absolute top-full right-0 mt-1 w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-fast"
             style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.6); padding: 6px;">
          <a href="/macro"     class="dropdown-item"><span class="w-2 h-2 rounded-full bg-loom-trigger inline-block mr-2"></span>Macro <span class="ml-auto text-[10px] px-1.5 py-0.5 rounded-chip bg-loom-trigger/10 text-loom-trigger font-bold tracking-button uppercase">Live</span></a>
          <a href="/scheduler" class="dropdown-item"><span class="w-2 h-2 rounded-full bg-loom-flow     inline-block mr-2"></span>Scheduler <span class="ml-auto text-[10px] px-1.5 py-0.5 rounded-chip bg-loom-flow/10 text-loom-flow font-bold tracking-button uppercase">Live</span></a>
          <a href="/cookbook"  class="dropdown-item"><span class="w-2 h-2 rounded-full bg-loom-action   inline-block mr-2"></span>Cookbook</a>
          <a href="/hardware"  class="dropdown-item"><span class="w-2 h-2 rounded-full bg-loom-sensor  inline-block mr-2"></span>Hardware <span class="ml-auto text-[10px] px-1.5 py-0.5 rounded-chip bg-loom-sensor/10 text-loom-sensor font-bold tracking-button uppercase">Live</span></a>
          <a href="/developer" class="dropdown-item"><span class="w-2 h-2 rounded-full bg-loom-variable inline-block mr-2"></span>Developer</a>
          <a href="/finance"   class="dropdown-item"><span class="w-2 h-2 rounded-full bg-loom-cyan    inline-block mr-2"></span>Finance</a>
        </div>
      </div>

      {links.map(l => (
        <a href={l.href} class={`nav-link ${activePage === l.href ? 'nav-link-active' : ''}`}>{l.label}</a>
      ))}

      <!-- Downloads quick-pick dropdown -->
      <div class="relative group ml-3">
        <button class="dl-trigger flex items-center gap-1">
          Downloads
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="opacity-40 transition-transform duration-fast group-hover:rotate-180">
            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute top-full right-0 mt-1 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-fast"
             style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.6); padding: 6px;">
          <a href="https://github.com/loch-suite/loch-macro-releases/releases/download/v0.2.0/Loch.Macro_0.2.0_x64-setup.exe"
             target="_blank" rel="noopener noreferrer"
             class="dropdown-item">
            <span class="w-2 h-2 rounded-full inline-block mr-2 flex-shrink-0" style="background: #f97316;"></span>
            <span class="flex-1">Macro</span>
            <span style="font-size: 9px; color: var(--text-muted); margin-left: 4px;">v0.2.0</span>
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="ml-2 opacity-40 flex-shrink-0">
              <path d="M5 1.5v5M2.5 4.5L5 7l2.5-2.5M1.5 9h7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="https://github.com/loch-suite/loch-hardware-releases/releases/download/v0.2.3/Loch.Hardware_0.2.3_x64-setup.exe"
             target="_blank" rel="noopener noreferrer"
             class="dropdown-item">
            <span class="w-2 h-2 rounded-full inline-block mr-2 flex-shrink-0" style="background: #10b981;"></span>
            <span class="flex-1">Hardware</span>
            <span style="font-size: 9px; color: var(--text-muted); margin-left: 4px;">v0.2.3</span>
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="ml-2 opacity-40 flex-shrink-0">
              <path d="M5 1.5v5M2.5 4.5L5 7l2.5-2.5M1.5 9h7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="https://github.com/loch-suite/loch-scheduler-releases/releases/download/v0.1.0/Loch.Scheduler_0.1.0_x64-setup.exe"
             target="_blank" rel="noopener noreferrer"
             class="dropdown-item">
            <span class="w-2 h-2 rounded-full inline-block mr-2 flex-shrink-0" style="background: #8b5cf6;"></span>
            <span class="flex-1">Scheduler</span>
            <span style="font-size: 9px; color: var(--text-muted); margin-left: 4px;">v0.1.0</span>
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="ml-2 opacity-40 flex-shrink-0">
              <path d="M5 1.5v5M2.5 4.5L5 7l2.5-2.5M1.5 9h7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div style="height: 1px; background: var(--border-faint); margin: 4px 2px;"></div>
          <a href="/downloads" class="dropdown-item" style="font-size: 10px; color: var(--text-muted);">
            All downloads →
          </a>
        </div>
      </div>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden p-2 rounded-input" style="color: var(--text-muted);" aria-label="Menu">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t" style="border-color: var(--border-subtle); background: var(--bg-elevated);">
    <div class="px-6 py-4 flex flex-col gap-1">
      <p class="label-section mb-2">Apps</p>
      <a href="/macro"     class="mobile-link">Macro <span class="badge-coming-soon ml-2" style="color: #f97316; border-color: rgba(249,115,22,0.3); background: rgba(249,115,22,0.1);">Live</span></a>
      <a href="/scheduler" class="mobile-link">Scheduler <span class="badge-coming-soon ml-2" style="color: #8b5cf6; border-color: rgba(139,92,246,0.3); background: rgba(139,92,246,0.1);">Live</span></a>
      <a href="/cookbook"  class="mobile-link">Cookbook</a>
      <a href="/hardware"  class="mobile-link">Hardware <span class="badge-coming-soon ml-2" style="color: #10b981; border-color: rgba(16,185,129,0.3); background: rgba(16,185,129,0.1);">Live</span></a>
      <a href="/developer" class="mobile-link">Developer</a>
      <a href="/finance"   class="mobile-link">Finance</a>
      <div class="my-2 border-t" style="border-color: var(--border-faint);"></div>
      {links.map(l => (
        <a href={l.href} class="mobile-link">{l.label}</a>
      ))}
      <div class="my-2 border-t" style="border-color: var(--border-faint);"></div>
      <p class="label-section mb-2">Quick Download</p>
      <a href="https://github.com/loch-suite/loch-macro-releases/releases/download/v0.2.0/Loch.Macro_0.2.0_x64-setup.exe"
         target="_blank" rel="noopener noreferrer" class="mobile-link">
        Macro <span style="font-size: 10px; color: var(--text-muted); margin-left: auto;">v0.2.0 ↓</span>
      </a>
      <a href="https://github.com/loch-suite/loch-hardware-releases/releases/download/v0.2.3/Loch.Hardware_0.2.3_x64-setup.exe"
         target="_blank" rel="noopener noreferrer" class="mobile-link">
        Hardware <span style="font-size: 10px; color: var(--text-muted); margin-left: auto;">v0.2.3 ↓</span>
      </a>
      <a href="https://github.com/loch-suite/loch-scheduler-releases/releases/download/v0.1.0/Loch.Scheduler_0.1.0_x64-setup.exe"
         target="_blank" rel="noopener noreferrer" class="mobile-link">
        Scheduler <span style="font-size: 10px; color: var(--text-muted); margin-left: auto;">v0.1.0 ↓</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .nav-link {
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 120ms ease, background 120ms ease;
  }
  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.05);
  }
  .nav-link-active {
    color: var(--text-primary);
  }
  .dl-trigger {
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: color 120ms ease, background 120ms ease;
  }
  .dl-trigger:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.05);
  }
  .dropdown-item {
    display: flex;
    align-items: center;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: background 80ms;
  }
  .dropdown-item:hover {
    background: var(--bg-raised);
    color: var(--text-primary);
  }
  .mobile-link {
    display: flex;
    align-items: center;
    padding: 8px 0;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--border-faint);
  }
  .mobile-link:last-child { border-bottom: none; }
  .mobile-link:hover { color: var(--text-primary); }

  #loom-nav {
    border-bottom: 1px solid var(--border-subtle);
    background: rgba(17, 17, 20, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
</style>

<script>
  // Mobile menu toggle
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
