---
import ComingSoonPage from '../components/ComingSoonPage.astro';
---
<ComingSoonPage
  id="cookbook"
  name="Loch Cookbook"
  tagline="Your personal command recipe book."
  description="Save, organize, and execute your most-used command sequences. Browse, search, and run recipes from a clean local interface — your terminal muscle memory, organized."
  colorHex="#3b82f6"
  category="Action"
  icon="C"
  features={[
    'Save shell commands, scripts, and multi-step sequences as recipes',
    'Tag and search across your entire recipe collection',
    'One-click execution with real-time output view',
    'Variable placeholders — fill in values at run time',
    'Import/export recipes as portable JSON',
    'Nested folders to organize by project or context',
  ]}
/>
