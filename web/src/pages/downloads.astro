---
import BaseLayout from '../layouts/BaseLayout.astro';
import SuiteInstallerUI from '../components/SuiteInstallerUI';
import { APPS } from '../data/apps';
---

<BaseLayout
  title="Downloads"
  description="Download Loom apps. Offline-first, no accounts, no cloud."
  activePage="/downloads"
>

  <!-- ─── Header ─────────────────────────────────────────────────── -->
  <section class="relative px-6 pt-32 pb-16 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="label-section mb-3 block">Downloads</span>
      <h1 class="page-title font-loom font-bold uppercase tracking-brand mb-4">Get Loom</h1>
      <p style="color: var(--text-secondary); font-size: 15px; max-width: 440px; margin: 0 auto;">
        All Loom apps are free, open source, and install with a single executable. No accounts required.
      </p>
    </div>
  </section>

  <!-- ─── Suite Installer concept ─────────────────────────────────── -->
  <section class="relative px-6 pb-20">
    <div class="max-w-3xl mx-auto">
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="label-section">Suite Installer</span>
          <span class="badge-coming-soon">Concept</span>
        </div>
        <h2 class="installer-heading">Build your Loom bundle.</h2>
        <p class="mt-2 text-sm" style="color: var(--text-muted); max-width: 480px;">
          Select the apps you want and generate a single installer that sets up your entire Loom suite.
          Only Macro is available now — others will unlock as they ship.
        </p>
      </div>

      <SuiteInstallerUI client:load />
    </div>
  </section>

  <!-- ─── Individual downloads ────────────────────────────────────── -->
  <section class="relative px-6 pb-24">
    <div class="max-w-3xl mx-auto">
      <div class="mb-6">
        <span class="label-section mb-2 block">Individual Apps</span>
        <h2 class="installer-heading">Download by app.</h2>
      </div>

      <div class="flex flex-col gap-3">
        {APPS.map(app => (
          <div class="download-row node-card" style={`border-left: 3px solid ${app.colorHex};`}>
            <div class="flex items-center gap-4 p-4">
              <!-- Icon -->
              <div class="flex-shrink-0 flex items-center justify-center font-bold text-base"
                   style={`width: 36px; height: 36px; border-radius: 8px; color: ${app.colorHex}; background: ${app.colorHex}18; border: 1px solid ${app.colorHex}30;`}>
                {app.icon}
              </div>

              <!-- Info -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5">
                  <p class="font-semibold text-sm" style="color: var(--text-primary);">{app.name}</p>
                  {app.version && (
                    <span style="font-size: 10px; color: var(--text-muted); font-variant-numeric: tabular-nums;">v{app.version}</span>
                  )}
                </div>
                <p style="font-size: 12px; color: var(--text-secondary);">{app.tagline}</p>
              </div>

              <!-- CTA -->
              <div class="flex-shrink-0 text-right">
                {app.shipped ? (
                  <a href={app.githubRelease}
                     target="_blank"
                     rel="noopener noreferrer"
                     class="dl-btn"
                     style={`--c: ${app.colorHex};`}>
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="mr-1">
                      <path d="M6 1.5v6M3.5 5.5L6 8l2.5-2.5M1.5 10h9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Windows &middot; ~{app.sizeMb}MB
                  </a>
                ) : (
                  <span class="badge-coming-soon">Coming Soon</span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── System requirements ─────────────────────────────────────── -->
  <section class="relative px-6 pb-24">
    <div class="max-w-3xl mx-auto">
      <div class="node-card p-6">
        <span class="label-section mb-4 block">System Requirements</span>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {[
            { label: 'OS',         value: 'Windows 10 version 1903 or later, Windows 11' },
            { label: 'Arch',       value: 'x64 (AMD64) · ARM64 (coming soon)' },
            { label: 'RAM',        value: '4 GB minimum, 8 GB recommended' },
            { label: 'Storage',    value: '50 MB per app (data stored separately)' },
            { label: 'Internet',   value: 'Not required — fully offline capable' },
            { label: 'Rights',     value: 'Standard user — no admin required' },
          ].map(r => (
            <div>
              <p class="label-section mb-1">{r.label}</p>
              <p style="font-size: 13px; color: var(--text-secondary);">{r.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-title {
    font-size: clamp(3rem, 10vw, 5.5rem);
    line-height: 1;
    color: var(--text-primary);
  }
  .installer-heading {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--text-primary);
  }
  .dl-btn {
    display: inline-flex;
    align-items: center;
    padding: 7px 14px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    background: color-mix(in srgb, var(--c) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 35%, transparent);
    color: var(--c);
    transition: background 180ms;
    white-space: nowrap;
  }
  .dl-btn:hover {
    background: color-mix(in srgb, var(--c) 22%, transparent);
  }
  .download-row {
    transition: transform 120ms;
    border-radius: 8px;
  }
  .download-row:hover {
    transform: translateX(2px);
  }
</style>
