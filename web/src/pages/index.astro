---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APPS } from '../data/apps';
---

<BaseLayout title="Home" activePage="/">

  <!-- ─── Hero ─────────────────────────────────────────────────── -->
  <section class="hero relative min-h-screen flex flex-col items-center justify-center px-6 text-center">

    <div class="relative z-10 flex flex-col items-center gap-5 max-w-3xl w-full">

      <!-- Logo mark (large) -->
      <div class="logo-mark" aria-hidden="true">
        <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" width="48" height="48"
             style="color: var(--text-primary);">
          <line x1="7"  y1="7"  x2="29" y2="7"  stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="7"  y1="29" x2="29" y2="29" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="7"  y1="7"  x2="7"  y2="29" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="29" y1="7"  x2="29" y2="29" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="7"  cy="7"  r="3.5" fill="currentColor"/>
          <circle cx="29" cy="7"  r="3.5" fill="currentColor"/>
          <circle cx="7"  cy="29" r="3.5" fill="currentColor"/>
          <circle cx="29" cy="29" r="3.5" fill="currentColor"/>
        </svg>
      </div>

      <!-- Wordmark -->
      <h1 class="wordmark font-display font-bold uppercase select-none">
        LOCH
      </h1>

      <!-- Suite label -->
      <div class="suite-rule">
        <div class="rule-line" aria-hidden="true"></div>
        <span class="label-section px-4">Desktop Utility Suite</span>
        <div class="rule-line" aria-hidden="true"></div>
      </div>

      <!-- Tagline -->
      <p class="tagline" style="color: var(--text-secondary); max-width: 520px;">
        Precision tools for Windows power users.
      </p>
      <p style="font-size: 13px; color: var(--text-muted); letter-spacing: 0.04em;">
        Local-first. No accounts. No telemetry.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-1">
        <a href="/macro" class="cta-primary-orange">
          Download Macro →
        </a>
        <a href="#suite" class="cta-secondary">
          Explore the Suite
        </a>
      </div>

      <!-- App strip: all 6 apps as equal-weight chips -->
      <div class="app-strip">
        {APPS.map(app => (
          <a href={app.slug} class="app-chip" style={`--ac: ${app.colorHex};`}>
            <span class="chip-dot" style={`background: ${app.colorHex};`}></span>
            <span class="chip-name">{app.name.replace('Loch ', '')}</span>
            {app.shipped
              ? <span class="chip-badge chip-live">Live</span>
              : <span class="chip-badge chip-soon">Soon</span>
            }
          </a>
        ))}
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <span style="font-size: 9px; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase;">Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ─── Suite grid ─────────────────────────────────────────────── -->
  <section id="suite" class="relative px-6 py-24">
    <div class="max-w-6xl mx-auto">
      <div class="mb-14 flex flex-col gap-2">
        <span class="label-section">The Suite</span>
        <h2 class="section-heading">A tool for every workflow.</h2>
        <p style="color: var(--text-secondary); font-size: 14px; max-width: 500px; margin-top: 6px; line-height: 1.7;">
          Each Loch app is standalone, offline-first, and shares the same design language.
          Build your own stack — use one app or all six.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {APPS.map((app) => (
          <a href={app.slug} class="node-card group block no-underline app-card">
            <div class="node-header flex items-start gap-3"
                 style={`border-left: 3px solid ${app.colorHex}; background: linear-gradient(90deg, ${app.colorHex}14 0%, transparent 60%);`}>
              <div class="app-icon-sm flex-shrink-0 flex items-center justify-center font-bold"
                   style={`color: ${app.colorHex}; background: ${app.colorHex}18; border: 1px solid ${app.colorHex}30; width: 32px; height: 32px; border-radius: 6px; font-size: 14px;`}>
                {app.icon}
              </div>
              <div class="flex-1 min-w-0 pt-0.5">
                <p class="label-section" style={`color: ${app.colorHex}; letter-spacing: 0.1em; margin-bottom: 2px;`}>{app.category}</p>
                <p class="font-semibold text-sm" style="color: var(--text-primary); letter-spacing: 0.02em;">{app.name}</p>
              </div>
              {app.shipped ? (
                <span class="flex-shrink-0 mt-0.5 px-2 py-0.5 rounded-chip text-[9px] font-bold tracking-button uppercase"
                      style="background: rgba(249,115,22,0.12); color: #f97316; border: 1px solid rgba(249,115,22,0.3);">
                  Live
                </span>
              ) : (
                <span class="badge-coming-soon flex-shrink-0 mt-0.5">Soon</span>
              )}
            </div>

            <div class="p-4">
              <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">{app.tagline}</p>
              <span class="inline-flex items-center gap-1 text-[11px] font-semibold tracking-button uppercase transition-all duration-fast"
                    style={`color: ${app.colorHex}; opacity: 0.7;`}>
                {app.shipped ? 'Download →' : 'Learn more →'}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Philosophy ───────────────────────────────────────────── -->
  <section class="relative px-6 py-24">
    <div class="max-w-6xl mx-auto">
      <div class="philosophy-panel node-card p-10 md:p-14">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <span class="label-section mb-3 block">Philosophy</span>
            <h2 class="section-heading mb-4" style="max-width: 380px;">
              Your data lives on your machine.
            </h2>
            <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
              Every Loch app stores its data locally in an open, inspectable format.
              No sync servers. No vendor lock-in. No subscriptions. You can open your data
              folder, read it, back it up, or delete it at any time.
            </p>
            <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
              We believe desktop software should respect your machine and your privacy.
              Loch runs entirely offline — no telemetry, no analytics, no internet required.
            </p>
          </div>

          <div class="flex flex-col gap-3">
            {[
              {
                label: 'Local-first',
                desc: 'Your data never leaves your machine. No cloud sync, no accounts, no servers.',
                svg: '<rect x="2" y="3" width="16" height="14" rx="2"/><path d="M6 7h.01M6 10h.01M6 13h.01M9 7h5M9 10h5M9 13h3"/>',
              },
              {
                label: 'Private by design',
                desc: 'No telemetry. No analytics. No crash reporting phoning home.',
                svg: '<rect x="5" y="9" width="10" height="8" rx="1.5"/><path d="M7 9V6.5a3 3 0 0 1 6 0V9"/><circle cx="10" cy="13" r="1"/>',
              },
              {
                label: 'Suite-native',
                desc: 'Every Loch app shares the same tokens, themes, and license system.',
                svg: '<path d="M10 2L3 6v4c0 4 3 7 7 8 4-1 7-4 7-8V6l-7-4z"/><path d="M7 10l2 2 4-4"/>',
              },
              {
                label: 'Windows-native',
                desc: 'Built with Tauri 2 for a tight, native Windows experience — not Electron.',
                svg: '<rect x="2" y="3" width="16" height="13" rx="2"/><path d="M2 7h16"/><circle cx="5" cy="5" r="0.75" fill="currentColor" stroke="none"/><circle cx="8" cy="5" r="0.75" fill="currentColor" stroke="none"/>',
              },
            ].map(({ svg, label, desc }) => (
              <div class="flex items-start gap-4 p-4 rounded-panel" style="background: var(--bg-base); border: 1px solid var(--border-faint);">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                     style="color: var(--text-muted); flex-shrink: 0; margin-top: 1px;" set:html={svg} />
                <div>
                  <p class="text-sm font-semibold mb-1" style="color: var(--text-primary);">{label}</p>
                  <p style="font-size: 12px; color: var(--text-secondary);">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Themes teaser ──────────────────────────────────────────── -->
  <section class="relative px-6 py-20" style="background: var(--bg-elevated); border-top: 1px solid var(--border-faint);">
    <div class="max-w-6xl mx-auto">
      <div class="mb-8 flex flex-col gap-1">
        <span class="label-section">Themes</span>
        <h2 class="section-heading" style="font-size: clamp(1.2rem, 3vw, 1.8rem);">13 themes. Free and premium.</h2>
        <p class="text-sm mt-1" style="color: var(--text-secondary); max-width: 420px;">
          Every Loch app ships with the same theme system — switch once, update everywhere.
        </p>
      </div>
      <div class="themes-strip">
        {[
          { name: 'Dusk',       bg: '#0a0a0c', pro: false },
          { name: 'Ash',        bg: '#0c0d11', pro: false },
          { name: 'Slate',      bg: '#060607', pro: false },
          { name: 'Fog',        bg: '#f0ede8', pro: false, dark: true },
          { name: 'Desert',     bg: '#0c0a06', pro: false },
          { name: 'Forest',     bg: '#060a06', pro: false },
          { name: 'Plum',       bg: '#080610', pro: false },
          { name: 'Arctic',     bg: '#040810', pro: false },
          { name: 'Rust',       bg: '#0c0706', pro: false },
          { name: 'Volcanic',   bg: '#0c0705', pro: true },
          { name: 'Depths',     bg: '#040c0e', pro: true },
          { name: 'Pixel City', bg: '#0a0806', pro: true },
          { name: 'Fireflies',  bg: '#030304', pro: true },
        ].map(({ name, bg, pro, dark }) => (
          <div class="theme-swatch" style={`background: ${bg};`}>
            <span class="swatch-label" style={dark ? 'color: rgba(10,10,12,0.5);' : ''}>{name.toUpperCase()}</span>
            {pro && <span class="swatch-pro">PRO</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Final CTA ────────────────────────────────────────────── -->
  <section class="relative px-6 py-24 text-center">
    <div class="max-w-xl mx-auto">
      <span class="label-section mb-4 block">Get started</span>
      <h2 class="section-heading mb-2">The suite is growing.</h2>
      <p class="text-sm mb-2" style="color: var(--text-secondary);">
        Loch Macro is the first app — available now, free, no accounts.
      </p>
      <p class="text-xs mb-8" style="color: var(--text-muted);">
        Five more apps are in development. Check back or watch the GitHub releases.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/macro"     class="cta-primary-orange">Download Macro →</a>
        <a href="/downloads" class="cta-secondary">View all downloads</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Wordmark ──────────────────────────────────────────────────── */
  .wordmark {
    font-size: clamp(3.5rem, 11vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: 0.18em;
    /* Top-bright → bottom-faded gradient: less "stamped", more composed */
    background: linear-gradient(170deg, rgba(245,245,247,0.88) 0%, rgba(245,245,247,0.50) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Logo mark pulse on hover ──────────────────────────────────── */
  .logo-mark {
    opacity: 0.85;
    transition: opacity 180ms ease;
  }
  .logo-mark:hover { opacity: 1; }

  /* ── Suite rule (horizontal line + label) ──────────────────────── */
  .suite-rule {
    display: flex;
    align-items: center;
    gap: 0;
    width: 100%;
    max-width: 480px;
  }
  .rule-line {
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  /* ── Tagline ───────────────────────────────────────────────────── */
  .tagline {
    font-size: clamp(14px, 2vw, 18px);
    line-height: 1.7;
  }

  /* ── CTAs ──────────────────────────────────────────────────────── */
  .cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    color: var(--text-primary);
    transition: background 180ms ease, border-color 180ms ease, transform 120ms ease;
  }
  .cta-primary:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.22);
    transform: translateY(-1px);
  }

  .cta-macro {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 18px;
    border-radius: 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    background: rgba(249,115,22,0.08);
    border: 1px solid rgba(249,115,22,0.25);
    color: rgba(249,115,22,0.85);
    transition: background 180ms ease;
  }
  .cta-macro:hover {
    background: rgba(249,115,22,0.14);
    color: #f97316;
  }
  .macro-live-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #f97316;
    box-shadow: 0 0 5px rgba(249,115,22,0.7);
    flex-shrink: 0;
    animation: live-pulse 2s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%, 100% { box-shadow: 0 0 5px rgba(249,115,22,0.7); }
    50%       { box-shadow: 0 0 10px rgba(249,115,22,1), 0 0 18px rgba(249,115,22,0.4); }
  }

  .cta-primary-orange {
    display: inline-flex;
    align-items: center;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    background: rgba(249,115,22,0.12);
    border: 1px solid rgba(249,115,22,0.4);
    color: #f97316;
    transition: background 180ms ease, transform 120ms ease;
  }
  .cta-primary-orange:hover {
    background: rgba(249,115,22,0.2);
    transform: translateY(-1px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-decoration: none;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    transition: background 180ms ease, color 120ms ease;
  }
  .cta-secondary:hover {
    background: rgba(255,255,255,0.08);
    color: var(--text-primary);
  }

  /* ── App strip ─────────────────────────────────────────────────── */
  .app-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin-top: 8px;
    max-width: 640px;
  }
  .app-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 500;
    text-decoration: none;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--text-secondary);
    transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
  }
  .app-chip:hover {
    background: color-mix(in srgb, var(--ac) 8%, rgba(255,255,255,0.03));
    border-color: color-mix(in srgb, var(--ac) 30%, transparent);
    color: var(--text-primary);
  }
  .chip-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .chip-name { letter-spacing: 0.02em; }
  .chip-badge {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 1px 5px;
    border-radius: 2px;
  }
  .chip-live {
    background: rgba(249,115,22,0.12);
    color: #f97316;
    border: 1px solid rgba(249,115,22,0.3);
  }
  .chip-soon {
    background: rgba(255,255,255,0.05);
    color: var(--text-muted);
    border: 1px solid rgba(255,255,255,0.07);
  }

  /* ── Scroll hint ───────────────────────────────────────────────── */
  .scroll-hint { opacity: 0.35; animation: scroll-bob 2.2s ease-in-out infinite; }
  .scroll-line { width: 1px; height: 32px; background: linear-gradient(to bottom, var(--text-muted), transparent); }
  @keyframes scroll-bob {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(5px); }
  }

  /* ── Section headings ──────────────────────────────────────────── */
  .section-heading {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    line-height: 1.15;
  }

  /* ── App card hover ────────────────────────────────────────────── */
  .app-card {
    transition: transform 180ms ease, box-shadow 180ms ease;
    text-decoration: none;
  }
  .app-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }

  .philosophy-panel { background: var(--bg-raised); }

  /* ── Themes strip ──────────────────────────────────────────────── */
  .themes-strip {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: none;
  }
  .themes-strip::-webkit-scrollbar { display: none; }

  .theme-swatch {
    flex: 0 0 76px;
    height: 50px;
    border-radius: 6px;
    border: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 6px;
    gap: 3px;
    position: relative;
  }

  .swatch-label {
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .swatch-pro {
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--variable);
    border: 1px solid rgba(245,158,11,0.35);
    border-radius: 2px;
    padding: 1px 4px;
  }
</style>
