---
import ComingSoonPage from '../components/ComingSoonPage.astro';
---
<ComingSoonPage
  id="finance"
  name="Loch Finance"
  tagline="Local-first personal finance."
  description="Budget, track expenses, and visualize spending — all stored on your machine. No bank sync, no cloud, no subscriptions. Your finances, your data."
  colorHex="#22d3ee"
  category="Monitor"
  icon="F"
  features={[
    'Manual transaction entry with category tagging',
    'Monthly budget planner with envelope-style tracking',
    'Spending charts and trend visualization — fully local',
    'Multi-account support — cash, checking, savings, credit',
    'CSV import from bank exports',
    'Open data format — view and edit your records in any spreadsheet',
  ]}
/>
