---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APPS } from '../data/apps';

const app = APPS.find(a => a.id === 'macro')!;
const COLOR = app.colorHex; // #f97316

const features = [
  {
    title: 'Visual Flow Editor',
    desc: 'Drag-and-drop canvas with 20+ built-in node types. Build complex macros by connecting nodes — no code, no syntax, no friction.',
    svg: '<circle cx="5" cy="10" r="2"/><circle cx="15" cy="5" r="2"/><circle cx="15" cy="15" r="2"/><path d="M7 10h3a1 1 0 0 0 1-1V6M7 10h3a1 1 0 0 1 1 1v3"/>',
  },
  {
    title: 'Trigger System',
    desc: 'Keyboard shortcuts, timers, window focus events, and hotkeys. Your macro starts exactly when and how you define.',
    svg: '<path d="M10 2v6l3 3"/><circle cx="10" cy="10" r="8"/>',
  },
  {
    title: 'Humanize Mode',
    desc: 'Adds subtle, realistic timing variation to mouse and keyboard actions. Macros feel human — because sometimes that matters.',
    svg: '<path d="M2 12c1.5-4 4-6 8-6s6.5 2 8 6"/><path d="M5 15c1-2.5 2.5-4 5-4s4 1.5 5 4"/><circle cx="10" cy="17" r="1.5"/>',
  },
  {
    title: 'Variable Engine',
    desc: 'Store, read, and transform values as your macro runs. Conditionals, loops, and dynamic data without writing a single line of code.',
    svg: '<path d="M4 6h3l2 8h2l2-8h3"/><path d="M3 14h14"/>',
  },
  {
    title: 'Multiple Profiles',
    desc: 'Organize macros by app, context, or project. Switch profiles instantly — and arm a specific macro to an always-ready hotkey.',
    svg: '<rect x="3" y="3" width="6" height="6" rx="1"/><rect x="11" y="3" width="6" height="6" rx="1"/><rect x="3" y="11" width="6" height="6" rx="1"/><rect x="11" y="11" width="6" height="6" rx="1"/>',
  },
  {
    title: 'Offline & Private',
    desc: 'No accounts. No cloud sync. No telemetry. Loch Macro stores everything in an open JSON format on your machine.',
    svg: '<path d="M10 2L3 5.5v5c0 3.8 3 7.2 7 8 4-.8 7-4.2 7-8v-5L10 2z"/><path d="M7 10l2 2 4-4"/>',
  },
];

const nodeTypes = [
  { name: 'Key Press',     cat: 'Trigger', color: COLOR },
  { name: 'Mouse Click',   cat: 'Action',  color: '#3b82f6' },
  { name: 'Delay',         cat: 'Flow',    color: '#8b5cf6' },
  { name: 'If Condition',  cat: 'Flow',    color: '#8b5cf6' },
  { name: 'Set Variable',  cat: 'Variable',color: '#f59e0b' },
  { name: 'Get Variable',  cat: 'Variable',color: '#f59e0b' },
  { name: 'Type Text',     cat: 'Action',  color: '#3b82f6' },
  { name: 'Screen Read',   cat: 'Sensor',  color: '#10b981' },
];
---

<BaseLayout title="Macro" description="Loch Macro — Node-based macro scripting for Windows. Automate anything." activePage="/macro">

  <!-- ─── Hero ──────────────────────────────────────────────────────── -->
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center px-6 text-center pt-20">
    <div class="hero-glow" aria-hidden="true" style={`--app-color: ${COLOR};`}></div>

    <div class="relative z-10 flex flex-col items-center gap-5 max-w-3xl">
      <div class="flex items-center gap-2">
        <div class="app-icon-lg flex items-center justify-center font-bold text-2xl"
             style={`color: ${COLOR}; background: ${COLOR}18; border: 1px solid ${COLOR}30;`}>
          M
        </div>
        <span class="label-section tracking-section" style={`color: ${COLOR};`}>Trigger · Loch Suite</span>
      </div>

      <h1 class="page-title font-loom font-bold uppercase tracking-brand">
        Loch Macro
      </h1>
      <p class="page-sub" style="color: var(--text-secondary); max-width: 520px;">
        Node-based macro scripting for Windows.<br/>
        Automate repetitive tasks with a visual flow editor — keyboard, mouse, and beyond.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 mt-2">
        <a href="https://github.com/vidathegoat/loom-macro/releases/latest"
           target="_blank" rel="noopener noreferrer"
           class="cta-download" style={`--c: ${COLOR};`}>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="mr-1.5">
            <path d="M7 2v7M4 6.5L7 9.5L10 6.5M2.5 11.5h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Download v{app.version}
        </a>
        <span class="text-xs" style="color: var(--text-muted);">Windows 10/11 &middot; ~{app.sizeMb}MB &middot; Free</span>
      </div>

      <!-- Version info -->
      <div class="version-pill">
        <span class="version-dot" style={`background: ${COLOR}; box-shadow: 0 0 6px ${COLOR}80;`}></span>
        Latest release: v{app.version} — stable
      </div>
    </div>
  </section>

  <!-- ─── Features ──────────────────────────────────────────────────── -->
  <section class="relative px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10">
        <span class="label-section mb-2 block">Features</span>
        <h2 class="section-heading">Everything you need to automate.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {features.map(f => (
          <div class="feature-card node-card p-5">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                 class="feature-icon mb-3" style={`color: ${COLOR};`} set:html={f.svg} />
            <h3 class="text-sm font-semibold mb-2 tracking-tight" style="color: var(--text-primary);">{f.title}</h3>
            <p style="font-size: 13px; color: var(--text-secondary); line-height: 1.6;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Node preview ──────────────────────────────────────────────── -->
  <section class="relative px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10">
        <span class="label-section mb-2 block">Node Library</span>
        <h2 class="section-heading">20+ nodes. Zero code.</h2>
        <p class="mt-3 text-sm" style="color: var(--text-secondary); max-width: 480px;">
          Every action, trigger, and control flow is a node. Connect them on the canvas to build any automation you can imagine.
        </p>
      </div>

      <!-- Simulated node cards -->
      <div class="node-canvas-preview">
        <div class="node-grid">
          {nodeTypes.map(n => (
            <div class="sim-node node-card">
              <div class="sim-node-header" style={`border-left: 3px solid ${n.color}; background: linear-gradient(90deg, ${n.color}14 0%, transparent 60%);`}>
                <p style={`font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: ${n.color}; margin-bottom: 2px;`}>{n.cat}</p>
                <p style="font-size: 12px; font-weight: 600; color: var(--text-primary); letter-spacing: 0.02em;">{n.name}</p>
              </div>
              <div class="sim-node-pins" style="padding: 8px 10px;">
                <div class="sim-pin" style={`--pc: ${n.color};`}>
                  <div class="pin-dot"></div>
                  <span>exec in</span>
                </div>
                <div class="sim-pin" style="--pc: rgba(255,255,255,0.75);">
                  <span style="margin-left: auto;">exec out</span>
                  <div class="pin-dot"></div>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="canvas-overlay" aria-hidden="true">
          <p class="label-section" style="letter-spacing: 0.1em;">Node Canvas Preview</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Screenshots placeholder ───────────────────────────────────── -->
  <section class="relative px-6 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10">
        <span class="label-section mb-2 block">Screenshots</span>
        <h2 class="section-heading">See it in action.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {['Flow Editor', 'Sidebar & Controls', 'Macro Profiles', 'Run Mode'].map(caption => (
          <div class="screenshot-placeholder node-card flex flex-col items-center justify-center gap-3 aspect-video">
            <div style="width: 40px; height: 40px; border: 1px solid var(--border-subtle); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="1.5" y="3" width="15" height="12" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="6" cy="7.5" r="1.5" stroke="currentColor" stroke-width="1.2"/>
                <path d="M1.5 12L5.5 9L8.5 11.5L12 8.5L16.5 12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </div>
            <p style="font-size: 11px; color: var(--text-muted);">{caption}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Download CTA ─────────────────────────────────────────────── -->
  <section class="relative px-6 py-24 text-center">
    <div class="max-w-lg mx-auto node-card p-10" style={`border-color: ${COLOR}30; box-shadow: 0 0 40px ${COLOR}08;`}>
      <span class="label-section mb-3 block" style={`color: ${COLOR};`}>Ready to automate?</span>
      <h2 class="section-heading mb-4">Download Macro free.</h2>
      <p class="text-sm mb-8" style="color: var(--text-secondary);">
        Windows 10 &amp; 11. No installer. No account. Drop the exe and run.
      </p>
      <a href="https://github.com/vidathegoat/loom-macro/releases/latest"
         target="_blank" rel="noopener noreferrer"
         class="cta-download" style={`--c: ${COLOR};`}>
        Download v{app.version} for Windows →
      </a>
      <p class="mt-4" style="font-size: 11px; color: var(--text-muted);">
        Apache-2.0 &middot; Source available &middot; ~{app.sizeMb}MB
      </p>
    </div>
  </section>

</BaseLayout>

<style define:vars={{ COLOR }}>
  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -60%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse, color-mix(in srgb, var(--app-color) 6%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }
  .app-icon-lg {
    width: 48px; height: 48px;
    border-radius: 10px;
    font-size: 22px;
  }
  .page-title {
    font-size: clamp(3rem, 10vw, 6rem);
    line-height: 1;
    letter-spacing: 0.12em;
    color: var(--text-primary);
  }
  .page-sub {
    font-size: clamp(14px, 2vw, 17px);
    line-height: 1.7;
  }
  .section-heading {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    line-height: 1.2;
  }

  /* Download CTA */
  .cta-download {
    display: inline-flex;
    align-items: center;
    padding: 11px 24px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    background: rgba(from var(--c, #f97316) r g b / 0.12);
    border: 1px solid rgba(from var(--c, #f97316) r g b / 0.4);
    color: var(--c, #f97316);
    transition: background 180ms ease, transform 120ms ease;
    /* Fallback for browsers without relative color syntax */
    background: color-mix(in srgb, var(--c, #f97316) 12%, transparent);
    border-color: color-mix(in srgb, var(--c, #f97316) 40%, transparent);
  }
  .cta-download:hover {
    background: color-mix(in srgb, var(--c, #f97316) 22%, transparent);
    transform: translateY(-1px);
  }

  .version-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px;
    border-radius: 99px;
    font-size: 11px;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
  }
  .version-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Features */
  .feature-card { transition: transform 180ms ease; }
  .feature-card:hover { transform: translateY(-2px); }
  .feature-icon {
    display: block;
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }

  /* Node canvas preview */
  .node-canvas-preview {
    position: relative;
    padding: 24px;
    border-radius: 10px;
    background: var(--bg-base);
    border: 1px solid var(--border-subtle);
    overflow: hidden;
    min-height: 280px;
  }
  .node-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
  }
  .sim-node { pointer-events: none; }
  .sim-node-header { padding: 8px 12px; border-bottom: 1px solid var(--border-faint); }
  .sim-pin {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    color: var(--text-muted);
    padding: 2px 0;
  }
  .pin-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--pc);
    box-shadow: 0 0 4px color-mix(in srgb, var(--pc) 50%, transparent);
    flex-shrink: 0;
  }
  .canvas-overlay {
    position: absolute;
    bottom: 12px;
    right: 16px;
    opacity: 0.5;
  }

  /* Screenshot placeholders */
  .screenshot-placeholder {
    background: var(--bg-base);
    min-height: 240px;
  }
</style>
