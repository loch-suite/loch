---
import ComingSoonPage from '../components/ComingSoonPage.astro';
---
<ComingSoonPage
  id="developer"
  name="Loch Developer"
  tagline="A toolkit for developers."
  description="Regex tester, JSON formatter, hash generator, base encoder, diff tool — all the small utilities you reach for daily, in one offline app. No browser tab required."
  colorHex="#f59e0b"
  category="Variable"
  icon="D"
  features={[
    'Regex tester with match highlighting and capture groups',
    'JSON / YAML / TOML formatter and validator',
    'Hash generator — MD5, SHA-1, SHA-256, SHA-512, bcrypt',
    'Base64, URL, and HTML encoder/decoder',
    'Text diff tool with side-by-side and unified views',
    'JWT decoder and inspector — no external calls',
  ]}
/>
