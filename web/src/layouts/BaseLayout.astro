---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TopoBackground from '../components/TopoBackground';
import GeoDecor from '../components/GeoDecor';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
  noFooter?: boolean;
}

const {
  title,
  description = 'Loch Suite — Precision tools for Windows power users. Local-first, no accounts, no telemetry.',
  activePage = '',
  noFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0c" />
    <title>{title} — Loch</title>

    <!-- Space Grotesk — display / wordmark font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title"       content={`${title} — Loch`} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Layer 0: topo animation (fixed, z:0) -->
    <TopoBackground client:only="react" />

    <!-- Layer 1: geometric decorations — dot matrices, plus signs, brackets (fixed, z:1) -->
    <GeoDecor client:only="react" />

    <!-- Layer 2: all page content (z:2) -->
    <div style="position: relative; z-index: 2;">
      <Nav activePage={activePage} />
      <slot />
      {!noFooter && <Footer />}
    </div>
  </body>
</html>
