---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TopoBackground from '../components/TopoBackground';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
  /** Set true to hide the footer (e.g. for full-bleed app pages) */
  noFooter?: boolean;
}

const {
  title,
  description = 'Loom — A suite of offline-first desktop utilities for Windows. No cloud, no accounts, no tracking.',
  activePage = '',
  noFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0c" />
    <title>{title} — Loom</title>

    <!-- Open Graph -->
    <meta property="og:title"       content={`${title} — Loom`} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Topo background — runs the full Loom Macro animation, fixed behind all content -->
    <TopoBackground client:only="react" />

    <!-- All page content sits above the topo canvas -->
    <div style="position: relative; z-index: 1;">
      <Nav activePage={activePage} />
      <slot />
      {!noFooter && <Footer />}
    </div>
  </body>
</html>
