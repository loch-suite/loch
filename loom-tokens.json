{
  "_comment": "Loom Design System — raw tokens. Source of truth: Loom Macro codebase.",

  "color": {
    "bg": {
      "base":     "#0a0a0c",
      "elevated": "#111114",
      "raised":   "#18181c"
    },
    "text": {
      "primary":   "#f5f5f7",
      "secondary": "rgba(245, 245, 247, 0.6)",
      "muted":     "rgba(245, 245, 247, 0.35)"
    },
    "border": {
      "subtle": "rgba(255, 255, 255, 0.08)",
      "faint":  "rgba(255, 255, 255, 0.04)"
    },
    "category": {
      "trigger":  "#f97316",
      "action":   "#3b82f6",
      "flow":     "#8b5cf6",
      "sensor":   "#10b981",
      "variable": "#f59e0b"
    },
    "pin": {
      "exec":    "rgba(255, 255, 255, 0.75)",
      "number":  "#60a5fa",
      "coord":   "#22d3ee",
      "boolean": "#4ade80",
      "string":  "#fb923c",
      "image":   "#c084fc",
      "color":   "#f472b6",
      "key":     "#fbbf24",
      "button":  "#94a3b8",
      "any":     "rgba(255, 255, 255, 0.45)",
      "varname": "#f59e0b",
      "monitor": "#64748b"
    },
    "state": {
      "error":          "#ef4444",
      "errorText":      "#f87171",
      "errorRing":      "rgba(239, 68, 68, 0.6)",
