      "armed":          "#4ade80",
      "armedGlow":      "rgba(74, 222, 128, 0.6)",
      "running":        "#f97316",
      "stop":           "#f87171",
      "stopRing":       "rgba(239, 68, 68, 0.4)",
      "updateAvail":    "rgb(249, 115, 22)",
      "updateReady":    "rgb(74, 222, 128)",
      "humanize":       "rgb(251, 191, 36)",
      "selection":      "rgba(234, 88, 12, 0.07)",
      "selectionBorder":"rgba(234, 88, 12, 0.45)",
